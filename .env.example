# MongoDB connection URL used by the ingestor service.
MONGO_URL=mongodb://db:27017
# Database name where spots are stored.
DB_NAME=spider_spots
# Collection name used to save spot documents.
COLLECTION_NAME=spots

# DX cluster host to connect to (local or remote).
DX_HOST=localhost
# DX cluster TCP port.
DX_PORT=7300
# Callsign used to authenticate/login in the DX cluster.
CALLSIGN=YOUR_CALLSIGN

# JWT signing secret for API authentication tokens.
SECRET_KEY=CHANGE_THIS_KEY_IN_PRODUCTION
# Password required by the login endpoint to obtain a token.
API_PASSWORD=CHANGE_THIS_PASSWORD

# Host interface where the Fastify API server listens.
SERVER_HOST=0.0.0.0
# Port where the Fastify API server listens.
SERVER_PORT=3000

# Number of spots buffered before doing a batch insert.
BUFFER_LIMIT=15
# Spot retention time in seconds (MongoDB TTL index).
TTL_SECONDS=604800
# Delay in milliseconds before reconnecting after socket disconnection.
RECONNECT_DELAY_MS=10000
